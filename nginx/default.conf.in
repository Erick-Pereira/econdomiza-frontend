# Só ${SIMCAG_GATEWAY_UPSTREAM} é substituído (docker-entrypoint.d/25-simcag-gateway.sh).
# Variáveis nginx ($uri, $host, …) mantêm um único $.

server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # O Docker resolve o nome do serviço na rede; o nginx, com proxy_pass fixo,
    # resolve o hostname ao CARREGAR a config — muitas vezes falha no arranque
    # ("host not found in upstream"). Resolver interno + URL em variável adia
    # a resolução para o primeiro pedido (usa o mesmo DNS 127.0.0.11 do Docker).
    resolver 127.0.0.11 valid=10s ipv6=off;
    resolver_timeout 5s;

    location /api/ {
        set $simcag_gateway "${SIMCAG_GATEWAY_UPSTREAM}";
        proxy_pass $simcag_gateway;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
    }
}
