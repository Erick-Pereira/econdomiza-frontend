# =============================================================================
# Econdomiza (frontend) — copiar para .env e ajustar:
#   cp .env.example .env
# =============================================================================
#
# Vite só expõe ao browser variáveis com prefixo VITE_.
# SIMCAG_GATEWAY_UPSTREAM é só para o container nginx (proxy /api → gateway).

# -----------------------------------------------------------------------------
# Desenvolvimento: npm run dev (Vite em http://localhost:5173)
# -----------------------------------------------------------------------------
# Base do gateway (sem / no fim). Para usar só o proxy do Vite em /api,
# deixe vazio: VITE_SIMCAG_GATEWAY_URL=
VITE_SIMCAG_GATEWAY_URL=http://localhost:5000

# Para onde o Vite encaminha os pedidos /api em dev (vite.config.ts)
VITE_DEV_PROXY_TARGET=http://localhost:5000

# Opcional: GUID para pré-preencher o Tenant ID em login/registo
# VITE_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000

# -----------------------------------------------------------------------------
# Imagem Docker (build): embutir URL da API no bundle
# -----------------------------------------------------------------------------
# Recomendado com nginx fazendo proxy de /api: deixe VAZIO no build para o
# JavaScript usar pedidos relativos /api... na mesma origem do site.
# Se precisar de URL absoluta (ex.: CDN separado), defina antes do build.
# VITE_SIMCAG_GATEWAY_URL=

# -----------------------------------------------------------------------------
# Container nginx (runtime): docker run -e / Docker Compose environment
# -----------------------------------------------------------------------------
# URL do gateway como o nginx VÊ a partir do container (não é a URL do browser).
# O hostname tem de ser o MESMO que o DNS interno da rede usa (nome do serviço
# no Compose ou --name do contentor), ex.: gateway-service — não misturar com
# outro nome por engano.
#   - Gateway no host (Docker Desktop): http://host.docker.internal:5000
#   - Linux sem host.docker.internal: docker run --add-host=host.docker.internal:host-gateway ...
#   - Serviço na mesma rede (Compose deste repo): http://gateway-service:8080
#     (porta dentro do contentor; :5000 no anfitrião é só o mapeamento host.)
SIMCAG_GATEWAY_UPSTREAM=http://host.docker.internal:5000
